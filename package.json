{
  "name": "axiroster",
  "version": "0.1.0",
  "description": "AxiRoster — Guild Wars 2 WvW guild roster management for guild leadership",
  "author": "darkharasho",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run --pool=forks --poolOptions.forks.maxForks=2",
    "test:watch": "vitest --pool=forks --poolOptions.forks.maxForks=2",
    "test:integration": "vitest run --pool=forks --poolOptions.forks.maxForks=2 tests/integration"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "gw2-class-icons": "^0.3.0",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.darkharasho.axiroster",
    "productName": "AxiRoster",
    "publish": [
      {
        "provider": "github",
        "owner": "darkharasho",
        "repo": "axiroster",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.icns"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "files": [
      "out/**/*",
      "package.json"
    ]
  }
}
